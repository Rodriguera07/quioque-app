# Copie este arquivo para ".env" e preencha com os valores do seu projeto
# Firebase (Console do Firebase > Configurações do projeto > Seus apps > SDK setup).
# Todas as chaves precisam do prefixo EXPO_PUBLIC_ para ficarem disponíveis no app.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
